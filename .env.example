# ============================================================
# WDB Backend – Umgebungsvariablen
# Kopieren nach: backend/.env
# NIEMALS .env committen (steht in .gitignore)
# ============================================================

# Allgemein
APP_NAME="WDB Backend"

# Datenbank (SQLite, relativ zum backend/-Verzeichnis)
SQLITE_PATH=data/wdb.sqlite3

# Ollama (lokaler AI-Provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_ENABLED=true

# Neo4j (Phase 2 – standardmäßig deaktiviert)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_ENABLED=false

# Feature Flags
NEO4J_SYNC_ENABLED=false   # Approved Results → Neo4j synchronisieren
